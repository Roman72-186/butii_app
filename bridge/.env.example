# Telegram Ads Bridge - Переменные окружения
# Скопируйте этот файл в .env и настройте свои значения

# URL вебхука Leadteh
# Это URL, который получает данные атрибуции
LEADTEH_WEBHOOK_URL=https://your-leadteh-account.leadteh.ru/inner_webhook/your-webhook-uuid

# API ключ Leadteh (если используется)
# LEADTEH_API_KEY=your_api_key_here

# ID бота в Leadteh (если используется)
# LEADTEH_BOT_ID=your_bot_id_here

# Необязательно: Токен бота Telegram для валидации initData (если реализуете серверную валидацию)
# TELEGRAM_BOT_TOKEN=your_bot_token_here