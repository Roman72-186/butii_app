PORT=3000
NODE_ENV=development

# Публичный URL Mini App.
PUBLIC_APP_URL=https://shop.sushi-house-39.online

# PostgreSQL. Если пусто, сервер запустится с in-memory хранилищем для демо.
DATABASE_URL=

# Минимум 32 символа. Нужен для подписи JWT-like session token.
JWT_SECRET=

# ЮMoney: номер кошелька и секрет HTTP-уведомлений.
YOOMONEY_RECEIVER=
YOOMONEY_NOTIFICATION_SECRET=
YOOMONEY_PAYMENT_TYPE=AC
YOOMONEY_ALLOW_UNSIGNED=false

# Опциональный внешний webhook для оплаченных заказов.
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
